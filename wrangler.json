{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "node",
  "main": "src/index.ts",
  "compatibility_date": "2025-02-04",
  "observability": {
    "enabled": true
  },
  "workers_dev": true,
  "migrations": [
    {
      "tag": "v2",
      "deleted_classes": ["DownloadCoalescer"]
    }
  ],
  "analytics_engine_datasets": [
    {
      "binding": "B2_ANALYTICS",
      "dataset": "b2_request_metrics"
    }
  ]
}
